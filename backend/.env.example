# =============================================================================
# Backend configuration
# Copy to .env and fill in. Variables marked REQUIRED will cause the app to
# fail to start if missing.
# =============================================================================

# === Twilio (REQUIRED) ===
# https://console.twilio.com — Account SID + Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# E.164 format, e.g. +14155551234
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# === App URLs (REQUIRED in production; defaults work for local dev) ===
# APP_BASE_URL: backend URL Twilio will call. In dev, set to your ngrok HTTPS URL.
# PUBLIC_URL:   used for the Twilio WebSocket callback (wss://). Defaults to APP_BASE_URL.
# FRONTEND_URL: where the React dashboard is served. Defaults to APP_BASE_URL.
# CORS_ORIGINS: comma-separated list of allowed browser origins.
APP_BASE_URL=http://localhost:8000
PUBLIC_URL=https://your-subdomain.ngrok-free.app
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === Database (REQUIRED) ===
# PostgreSQL connection string. Format:
#   postgresql://user:password@host:5432/dbname
# For local dev with Docker: postgresql://postgres:postgres@localhost:5432/frontline_ai
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frontline_ai

# === Google AI / Gemini (REQUIRED) ===
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Speech activity detection tuning for Gemini Live voice (optional).
# Sensitivity: LOW | MEDIUM | HIGH. Lower silence_duration_ms = snappier turn-taking.
SILENCE_DURATION_MS=250
END_SPEECH_SENSITIVITY=LOW
START_SPEECH_SENSITIVITY=HIGH

# === Google OAuth — sign-in + Calendar tools (REQUIRED) ===
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
# Authorized redirect URIs (add both):
#   {APP_BASE_URL}/auth/callback
#   {APP_BASE_URL}/auth/calendar/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Session-token signing key (REQUIRED). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-32-byte-hex

# === Email / SMTP (OPTIONAL — call-summary emails are skipped if blank) ===
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
